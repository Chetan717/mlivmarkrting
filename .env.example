# ─────────────────────────────────────────────────────────────────────────────
# Firebase Configuration
# Copy this file to .env and fill in your actual values.
# On Vercel: add each variable in Project → Settings → Environment Variables.
# NEVER commit your .env file to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# Firestore Collection Names
# Keep these secret — do not expose real collection names in public code.
# Set the actual names in your .env / Vercel env, not here.
# ─────────────────────────────────────────────────────────────────────────────

VITE_COLL_MTEAM=mteam
VITE_COLL_COUPONCODE=couponcode
VITE_COLL_SUBSCRIPTION=subscription
VITE_COLL_USERS=users
VITE_COLL_MLMPROFILES=mlmprofiles
VITE_COLL_LEADS=leadBysubuserMarketingMember
